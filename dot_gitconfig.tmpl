# Managed by chezmoi - source: ~/.local/share/chezmoi/dot_gitconfig.tmpl
# Shared, cross-machine git config. Identity + machine-specific paths (e.g.
# core.hooksPath) live in ~/.gitconfig.local (untracked, per-machine) via the
# [include] at the bottom.

[core]
    pager = delta
{{- if eq .chezmoi.os "windows" }}
    editor = code --wait
    autocrlf = false
{{- else }}
    editor = vim
{{- end }}

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true
    side-by-side = true
    line-numbers = true
    syntax-theme = Dracula
    plus-style = "syntax #2a4a2a"
    minus-style = "syntax #4a2a2a"

[merge]
    conflictstyle = diff3

[diff]
    colorMoved = default

[init]
    defaultBranch = main

[pull]
    rebase = true

[alias]
    last = log --oneline -10
    review = diff --cached
    unstage = reset HEAD --
    amend = commit --amend --no-edit
    wip = !git add -A && git commit -m "wip"

# Identity + machine-specific overrides - untracked, created per-machine.
[include]
    path = {{ .chezmoi.homeDir }}/.gitconfig.local
